# terraform.tfvars のサンプル。
# このファイルをコピーして terraform.tfvars を作り、自分の値に書き換える。
#   cp terraform.tfvars.example terraform.tfvars
#
# my_ip_cidr は SSH を許可する自分のグローバルIP。次のコマンドで確認できる:
#   echo "$(curl -s https://checkip.amazonaws.com)/32"

my_ip_cidr      = "1.2.3.4/32"
public_key_path = "~/.ssh/taskmanagement-ec2.pub"
# instance_type = "t3.micro"   # 変えたい場合のみ
# aws_region    = "ap-northeast-1"
